# TicketSeat E2E Environment Variables
# Copy to .env and fill in values

# Base URLs for each application
BASE_URL_LANDING=https://landing-dev.ticketseat.io
BASE_URL_ADMIN=https://admin-dev.ticketseat.io
BASE_URL_STORE=https://store-dev.ticketseat.io
BASE_URL_API=https://backend-dev.ticketseat.io

# Test admin credentials (email is auto-generated per run with timestamp)
TEST_ADMIN_EMAIL=e2e-test-{timestamp}@ticketseat-test.io
TEST_ADMIN_PASSWORD=TestE2E_2026!
TEST_ADMIN_FIRST_NAME=E2E
TEST_ADMIN_LAST_NAME=Tester
TEST_ADMIN_PHONE=+15550001234

# Stripe test mode
STRIPE_TEST_CARD=4242424242424242
STRIPE_TEST_CARD_3DS=4000002760003184
STRIPE_TEST_CARD_DECLINED=4000000000009995
STRIPE_TEST_EXPIRY=12/28
STRIPE_TEST_CVC=123
STRIPE_TEST_ZIP=12345

# Optional: override test run uniqueness
# TEST_RUN_ID=custom-id
